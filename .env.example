# plugin-zigbee2mqtt environment
# For local discovery mode, PLUGIN_DATA_DIR and MQTT configuration are required.
# Copy to .env.local and customize with real values.

# Required: Directory for plugin state storage
PLUGIN_DATA_DIR=/tmp/plugin-zigbee2mqtt

# Required: MQTT broker configuration
ZIGBEE2MQTT_MQTT_URL=tcp://127.0.0.1:1883
ZIGBEE2MQTT_USERNAME=
ZIGBEE2MQTT_PASSWORD=

# Required: Discovery topic for Home Assistant style discovery
ZIGBEE2MQTT_DISCOVERY_TOPIC=homeassistant/#

# Required: Base topic for zigbee2mqtt
ZIGBEE2MQTT_BASE_TOPIC=zigbee2mqtt

# Compatibility aliases (still supported):
# Z2M_MQTT_BROKER_URL, Z2M_DISCOVERY_TOPIC, Z2M_BASE_TOPIC,
# Z2M_USERNAME, Z2M_PASSWORD, MQTT_URL, MQTT_DISCOVERY_TOPIC.
